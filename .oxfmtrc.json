{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "avoid",
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 80,
  "sortPackageJson": false,
  "sortImports": {
    "ignoreCase": false,
    "newlinesBetween": true,
    "groups": [
      ["side_effect"],
      ["builtin"],
      ["external"],
      ["parent"],
      ["sibling"],
      ["index"]
    ]
  }
}
